{
  "name": "OpenManual",
  "description": "AI 친화적인 오픈소스 문서 시스템 프레임워크",
  "favicon": "/favicon.svg",
  "siteUrl": "https://openmanual.shenjingnan.com",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo-dark.svg"
  },
  "contentDir": "content",
  "outputDir": "dist",
  "locale": "zh",
  "i18n": {
    "enabled": true,
    "defaultLanguage": "zh",
    "parser": "dir",
    "languages": [
      { "code": "zh", "name": "中文" },
      { "code": "en", "name": "English" },
      { "code": "ja", "name": "日本語" },
      { "code": "ko", "name": "한국어" }
    ]
  },
  "navbar": {
    "github": "https://github.com/shenjingnan/openmanual"
  },
  "theme": {
    "primaryHue": 213,
    "darkMode": true
  },
  "search": {
    "position": "header"
  },
  "mdx": {
    "latex": true
  },
  "openapi": {
    "specPath": "openapi.yaml"
  }
}
