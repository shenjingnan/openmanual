{
  "name": "OpenManual",
  "description": "AI 친화적인 오픈소스 문서 시스템 프레임워크",
  "favicon": "/favicon.svg",
  "siteUrl": "https://openmanual.shenjingnan.com",
  "contentDir": "content",
  "outputDir": "dist",
  "locale": "zh",
  "i18n": {
    "enabled": true,
    "defaultLanguage": "zh",
    "parser": "dir",
    "languages": [
      { "code": "zh", "name": "中文" },
      { "code": "en", "name": "English" },
      { "code": "ja", "name": "日本語" },
      { "code": "ko", "name": "한국어" }
    ]
  },
  "header": {
    "height": "56px",
    "logo": {
      "light": "/logo.svg",
      "dark": "/logo-dark.svg"
    },
    "links": [
      { "icon": "bot", "href": "https://github.com/shenjingnan/openmanual" },
      { "icon": "/icons/github-fill.svg", "href": "https://github.com/shenjingnan/openmanual" },
      {
        "icon": "/icons/github-fill.svg",
        "label": "GitHub",
        "href": "https://github.com/shenjingnan/openmanual"
      },
      { "label": "GitHub", "href": "https://github.com/shenjingnan/openmanual" }
    ]
  },
  "navbar": {
    "github": "https://github.com/shenjingnan/openmanual"
  },
  "theme": {
    "primaryHue": 213,
    "darkMode": true
  },
  "search": {
    "enabled": true
  },
  "mdx": {
    "latex": true
  },
  "openapi": {
    "specPath": "openapi.yaml"
  }
}
