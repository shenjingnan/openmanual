{
  "name": "OpenManual",
  "description": "AI 友好的开源文档系统框架",
  "favicon": "/favicon.svg",
  "siteUrl": "https://openmanual.shenjingnan.com",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo-dark.svg",
    "position": "header"
  },
  "locale": "zh",
  "header": {
    "links": [
      { "icon": "/icons/github-fill.svg", "href": "https://github.com/shenjingnan/openmanual" }
    ]
  },
  "i18n": {
    "enabled": true,
    "defaultLanguage": "zh",
    "parser": "dir",
    "languages": [
      { "code": "zh", "name": "中文" },
      { "code": "en", "name": "English" },
      { "code": "ja", "name": "日本語" },
      { "code": "ko", "name": "한국어" }
    ]
  },
  "search": {
    "position": "header"
  },
  "navbar": {
    "github": "https://github.com/shenjingnan/openmanual"
  },
  "openapi": {
    "specPath": "openapi.yaml"
  }
}
