{
  "name": "OpenManual",
  "description": "AI 友好的开源文档系统框架",
  "favicon": "/favicon.svg",
  "siteUrl": "https://openmanual.dev",
  "contentDir": "content",
  "outputDir": "docs-dist",
  "locale": "zh",
  "i18n": {
    "enabled": true,
    "defaultLanguage": "zh",
    "parser": "dir",
    "languages": [{ "code": "zh", "name": "中文" }, { "code": "en", "name": "English" }]
  },
  "navbar": {
    "logo": {
      "light": "/logo.svg",
      "dark": "/logo-dark.svg"
    },
    "github": "https://github.com/shenjingnan/openmanual"
  },
  "sidebar": [
    {
      "group": "开始",
      "icon": "Rocket",
      "collapsed": false,
      "pages": [
        { "slug": "index", "title": "项目介绍", "icon": "Home" },
        { "slug": "quickstart", "title": "快速上手", "icon": "Zap" }
      ]
    },
    {
      "group": "指南",
      "icon": "BookOpen",
      "collapsed": true,
      "pages": [
        { "slug": "guide/configuration", "title": "配置参考", "icon": "Settings" },
        { "slug": "guide/writing-docs", "title": "编写文档", "icon": "FileText" },
        { "slug": "guide/sidebar", "title": "侧边栏定制", "icon": "PanelLeft" },
        { "slug": "guide/theme", "title": "主题定制", "icon": "Palette" },
        { "slug": "guide/deployment", "title": "部署", "icon": "Cloud" }
      ]
    },
    {
      "group": "组件",
      "icon": "Layout",
      "collapsed": true,
      "pages": [
        { "slug": "components/callout", "title": "Callout 提示框", "icon": "MessageSquare" },
        { "slug": "components/card", "title": "Card 卡片", "icon": "Square" },
        { "slug": "components/steps", "title": "Steps 步骤", "icon": "ListOrdered" },
        { "slug": "components/tabs", "title": "Tabs 标签页", "icon": "Columns" },
        { "slug": "components/files", "title": "Files 文件树", "icon": "FolderTree" },
        { "slug": "components/accordion", "title": "Accordion 折叠面板", "icon": "ChevronDown" },
        { "slug": "components/type-table", "title": "TypeTable 类型表格", "icon": "Table" }
      ]
    },
    {
      "group": "进阶",
      "icon": "Wrench",
      "collapsed": true,
      "pages": [
        { "slug": "advanced/search", "title": "搜索配置", "icon": "Search" },
        { "slug": "advanced/mdx", "title": "MDX 增强", "icon": "Sparkles" }
      ]
    },
    {
      "group": "社区",
      "icon": "Users",
      "collapsed": true,
      "pages": [
        { "slug": "community/contributing", "title": "贡献指南", "icon": "Heart" },
        { "slug": "community/changelog", "title": "更新日志", "icon": "Calendar" }
      ]
    }
  ],
  "theme": {
    "primaryHue": 213,
    "darkMode": true
  },
  "search": {
    "enabled": true
  },
  "mdx": {
    "latex": true
  }
}
