{
  "name": "openmanual",
  "version": "0.8.2",
  "author": "shenjingnan <sjn.code@gmail.com>",
  "description": "AI 友好的开源文档系统框架",
  "type": "module",
  "bin": {
    "om": "./dist/bin.js",
    "openmanual": "./dist/bin.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  },
  "files": [
    "dist",
    "logo.svg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:cli": "tsx watch src/cli/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint",
    "check:fix": "pnpm run typecheck && pnpm run lint:fix && pnpm run format",
    "docs:dev": "cd docs && pnpm run dev",
    "docs:build": "cd docs && pnpm run build",
    "spellcheck": "cspell \"**/*.ts\" \"**/*.md\"",
    "prepare": "husky",
    "release": "release-it",
    "release:beta": "release-it --preRelease=beta --ci",
    "release:dry": "release-it --dry-run --ci",
    "release:patch": "release-it patch --ci",
    "release:minor": "release-it minor --ci",
    "release:major": "release-it major --ci"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "keywords": [
    "documentation",
    "mdx",
    "fumadocs",
    "nextjs",
    "openmanual"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shenjingnan/openmanual.git"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "fumadocs-core": "^16.7.7",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.7",
    "gray-matter": "^4.0.3",
    "next": "^16.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "mermaid": ">=11.0.0",
    "next-themes": ">=0.4.0",
    "tailwind-merge": ">=2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@release-it/conventional-changelog": "^9.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.2.1",
    "cspell": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "release-it": "^17.10.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  }
}
