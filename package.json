{
  "name": "openmanual",
  "version": "0.1.0",
  "description": "AI 友好的开源文档系统框架",
  "type": "module",
  "bin": {
    "openmanual": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint",
    "check:fix": "pnpm run typecheck && pnpm run lint:fix && pnpm run format",
    "docs:dev": "cd docs && pnpm run dev",
    "docs:build": "cd docs && pnpm run build",
    "docs:preview": "cd docs && pnpm run preview",
    "spellcheck": "cspell \"**/*.ts\" \"**/*.md\"",
    "prepare": "husky",
    "release": "release-it"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "keywords": [
    "documentation",
    "mdx",
    "fumadocs",
    "nextjs",
    "openmanual"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shenjingnan/openmanual.git"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "fumadocs-core": "^16.7.7",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.7",
    "gray-matter": "^4.0.3",
    "next": "^16.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@release-it/conventional-changelog": "^9.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^2.1.8",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "release-it": "^17.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  }
}
